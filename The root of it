}

// ============================================================
// JUMP TO SECTION
// ============================================================
function jumpTo(anchorId) {
  const el = document.getElementById(anchorId);
  if(!el) return;
  const offset = 70; // account for sticky nav height
  const top = el.getBoundingClientRect().top + window.scrollY - offset;
  window.scrollTo({ top, behavior: 'smooth' });
}

// ============================================================
// DUPLICATE CARD ROW
// ============================================================
function duplicateCardRow(btn) {
  const row = btn.closest('.spread-card-row');
  if(!row) return;

  const deck = row.querySelector('.spread-deck').value;
  const position = row.querySelector('.spread-position').value;
  const card = row.querySelector('.spread-card').value;
  const orientation = row.querySelector('.spread-orientation').value;
  const notes = row.querySelector('.spread-notes').value;

  // Insert the new row right after the current one
  const container = document.getElementById('spreadCards');
  const newRow = document.createElement('div');
  newRow.className = 'spread-card-row';
  newRow.innerHTML = row.innerHTML;
  container.insertBefore(newRow, row.nextSibling);

  // Re-populate the card select since innerHTML doesn't carry option states reliably
  const newDeckSelect = newRow.querySelector('.spread-deck');
  const newCardSelect = newRow.querySelector('.spread-card');
  const newOrientation = newRow.querySelector('.spread-orientation');
  const newPosition = newRow.querySelector('.spread-position');
  const newNotes = newRow.querySelector('.spread-notes');

  newDeckSelect.value = deck;
  newOrientation.value = orientation;
  newPosition.value = position;
  newNotes.value = notes;

  if(deck) {
    populateCardOptions(newCardSelect, deck, card);
  }
}

// ============================================================
// ROW REORDERING — up/down buttons
// ============================================================
function moveRow(btn, direction) {
  const row = btn.closest('.spread-card-row, .spread-section-header');
  const container = document.getElementById('spreadCards');
  if(!row || !container) return;
  if(direction === -1) {
    const prev = row.previousElementSibling;
    if(prev) container.insertBefore(row, prev);
  } else {
    const next = row.nextElementSibling;
    if(next) container.insertBefore(next, row);
  }
}

